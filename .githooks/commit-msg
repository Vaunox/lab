#!/usr/bin/env bash
# Strips any authorship attribution trailer, regardless of origin.
# Belt and braces: one missed commit is permanent in a public history.
#
# Portable across GNU and BSD userlands (operator ruling R-004). The previous
# implementation used `sed -i.bak -E '/.../Id'`; the `I` case-insensitivity
# address modifier is a GNU extension that BSD sed rejects, so on macos-latest
# the hook failed rather than stripping -- silently removing one of the three
# attribution layers on a platform section 5.2 calls supported, not assumed.
#
# `grep -i -v -E` is POSIX and behaves identically on both. It exits 1 when
# every line is filtered out, which is not an error here, hence the guard.
set -euo pipefail

MSG="$1"
TMP="$MSG.stripped"

grep -ivE '^(Co-Authored-By|Co-authored-by):' "$MSG" \
  | grep -ivE '(Generated with|Generated by|Assisted by|Written by Claude|🤖)' \
  > "$TMP" || true

mv "$TMP" "$MSG"
