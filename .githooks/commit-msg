#!/usr/bin/env bash
# Strips any authorship attribution trailer, regardless of origin.
# Belt and braces: one missed commit is permanent in a public history.
set -euo pipefail
MSG="$1"
sed -i.bak -E '/^(Co-Authored-By|Co-authored-by):/Id' "$MSG"
sed -i.bak -E '/(Generated with|Generated by|Assisted by|🤖)/Id' "$MSG"
rm -f "$MSG.bak"
